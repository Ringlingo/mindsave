# MindSave .gitignore

# Ignore runtime data (keep directory structure via .gitkeep)
.mindsave/snapshots/*
!.mindsave/snapshots/.gitkeep
!.mindsave/snapshots/example_snapshot.md
.mindsave/tool_logs/*
!.mindsave/tool_logs/.gitkeep
!.mindsave/tool_logs/example-session.jsonl

# v4 runtime data (index.db, segments/, embeddings/) — never commit
**/.mindsave/v4/

# Runtime heartbeat (environment-specific)
.mindsave/signal.json

# Keep index and gitkeep
!.mindsave/index.json

# Version history (local only — not for open source)
versions/

# OS
.DS_Store
Thumbs.db

# Dependencies
node_modules/
__pycache__/
*.pyc

# Build output
dist/
*.egg-info/

# Test temp
.test-temp/
.coverage
.pytest_cache/
